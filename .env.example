# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hsi

# NextAuth
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Email (Resend)
RESEND_API_KEY=re_...
AUTH_RESEND_KEY=re_...
AUTH_FROM_EMAIL=noreply@yourdomain.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# EasyPanel / Build
# CRITICAL: Set PRISMA_GENERATE_SKIP_AUTOINSTALL=true in EasyPanel build env
# before the first build. Prevents prisma from installing binaries at build time.
PRISMA_GENERATE_SKIP_AUTOINSTALL=true

# IMPORTANT: All NEXT_PUBLIC_* variables are baked at BUILD TIME by Next.js.
# They must be configured in EasyPanel BEFORE triggering the first build.
# Changing them after a build requires a full rebuild.
